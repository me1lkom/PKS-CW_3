<Window
    x:Class="WpfHttpServer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfHttpServer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="600"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock
                FontSize="16"
                FontWeight="Bold"
                Text="СЕРВЕР" />
            <TextBlock Margin="0,10,0,0" Text="Порт:" />
            <TextBox
                x:Name="PortTextBox"
                Margin="0,5,0,10"
                Text="8080" />
            <Button
                x:Name="StartServerButton"
                Click="StartServerButton_Click"
                Content="Запустить сервер" />
            <TextBlock Margin="0,10,0,0" Text="Логи:" />
            <TextBox
                x:Name="LogTextBox"
                Height="300"
                AcceptsReturn="True"
                IsReadOnly="True"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock
                FontSize="16"
                FontWeight="Bold"
                Text="КЛИЕНТ" />
            <TextBlock Margin="0,10,0,0" Text="URL:" />
            <TextBox
                x:Name="UrlTextBox"
                Margin="0,5,0,10"
                Text="https://localhost:8080/" />
            <ComboBox x:Name="MethodComboBox" Margin="0,0,0,10">
                <ComboBoxItem Content="GET" IsSelected="True" />
                <ComboBoxItem Content="POST" />
            </ComboBox>
            <TextBlock Text="Тело запроса (JSON для POST):" />
            <TextBox
                x:Name="BodyTextBox"
                Height="100"
                Margin="0,5,0,10"
                TextWrapping="Wrap" />
            <Button x:Name="SendRequestButton" Content="Отправить запрос" />
            <TextBlock Margin="0,10,0,0" Text="Ответ:" />
            <TextBox
                x:Name="ResponseTextBox"
                Height="150"
                IsReadOnly="True"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
