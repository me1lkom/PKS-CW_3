<Window
    x:Class="WpfHttpServer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfHttpServer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxy="http://oxyplot.org/wpf"
    Title="MainWindow"
    Width="1000"
    Height="700"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock
                FontSize="16"
                FontWeight="Bold"
                Text="СЕРВЕР" />
            <TextBlock Margin="0,10,0,0" Text="Порт:" />
            <TextBox
                x:Name="PortTextBox"
                Margin="0,5,0,10"
                Text="8080" />
            <Button
                x:Name="StartServerButton"
                Click="StartServerButton_Click"
                Content="Запустить сервер" />
            <Button
                x:Name="DownloadLogsButton"
                Margin="0,10,0,0"
                Click="DownloadLogsButton_Click"
                Content="Скачать логи" />
            <TextBlock Margin="0,5,0,0" Text="Логи:" />
            <ComboBox x:Name="FiterLogs" Margin="0,5,0,5">
                <ComboBoxItem Content="Всё" IsSelected="True" />
                <ComboBoxItem Content="GET" />
                <ComboBoxItem Content="POST" />
                <ComboBoxItem Content="Ошибки" />
            </ComboBox>
            <Button
                x:Name="ApplyFilterLogsButton"
                Click="ApplyFilterLogsButton_Click"
                Content="Применить фильтр" />
            <TextBox
                x:Name="LogTextBox"
                Height="200"
                AcceptsReturn="True"
                IsReadOnly="True"
                TextWrapping="Wrap" />

            <Border
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0">
                <oxy:PlotView
                    x:Name="LoadChart"
                    Height="200"
                    Margin="0,10,0,0" />

            </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock
                FontSize="16"
                FontWeight="Bold"
                Text="КЛИЕНТ" />
            <TextBlock Margin="0,10,0,0" Text="URL:" />
            <TextBox
                x:Name="UrlTextBox"
                Margin="0,5,0,10"
                Text="http://localhost:8080/" />
            <ComboBox x:Name="MethodComboBox" Margin="0,0,0,10">
                <ComboBoxItem Content="GET" IsSelected="True" />
                <ComboBoxItem Content="POST" />
            </ComboBox>
            <TextBlock Text="Тело запроса:" />
            <TextBox
                x:Name="BodyTextBox"
                Height="100"
                Margin="0,5,0,10"
                TextWrapping="Wrap">
                <TextBox.Text>
                    {"message":"Привет!"}
                </TextBox.Text>
            </TextBox>
            <Button
                x:Name="SendRequestButton"
                Click="SendRequestButton_Click"
                Content="Отправить запрос" />
            <TextBlock Margin="0,10,0,0" Text="Ответ:" />
            <TextBox
                x:Name="ResponseTextBox"
                Height="150"
                IsReadOnly="True"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
